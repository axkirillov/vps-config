# /etc/fstab: static file system information.
#
# Use 'blkid' to print the universally unique identifier for a
# device; this may be used with UUID= as a more robust way to name devices
# that works even if disks are added and removed. See fstab(5).
#
# <file system> <mount point>   <type>  <options>       <dump>  <pass>
# / was on /dev/sda3 during curtin installation
/dev/disk/by-uuid/5e6f1593-c3dd-45e2-bf7a-27b3cd9ef023 / ext4 defaults 0 1
# /boot/efi was on /dev/sda2 during curtin installation
/dev/disk/by-uuid/3ED7-13F3 /boot/efi vfat defaults 0 1

//u571770.your-storagebox.de/backup /mnt/storagebox cifs vers=3.0,credentials=/root/.smbcredentials,uid=1000,gid=1000,file_mode=0660,dir_mode=0770 0 0

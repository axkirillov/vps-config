{
    email ssl@axkirillov.com
}

photos.axkirillov.com {
    reverse_proxy 127.0.0.1:2283
}

cloud.axkirillov.com {
    reverse_proxy https://127.0.0.1:8080 {
        transport http {
            tls_insecure_skip_verify
        }
    }
}

blog.axkirillov.com {
    reverse_proxy 127.0.0.1:2368
}

supabase.axkirillov.com {
    # CORS
    header Access-Control-Allow-Origin *
    header Access-Control-Allow-Headers "Authorization, Content-Type, apikey, X-Client-Info, Prefer"
    header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"

    # Handle CORS preflight
    @options method OPTIONS
    respond @options 204

    # Auth (GoTrue) — strip /auth/v1 prefix
    handle_path /auth/v1/* {
        reverse_proxy 127.0.0.1:9999 {
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Allow-Methods
        }
    }
    # PostgREST REST API (strip /rest/v1 prefix)
    handle_path /rest/v1/* {
        reverse_proxy 127.0.0.1:3001 {
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Allow-Methods
        }
    }
    # Realtime WebSocket — rewrite /realtime/v1/ to /socket/
    handle /realtime/v1/* {
        uri replace "/realtime/v1/" "/socket/"
        reverse_proxy 127.0.0.1:4000 {
            header_down -Access-Control-Allow-Origin
            header_down -Access-Control-Allow-Headers
            header_down -Access-Control-Allow-Methods
        }
    }
    # Catch-all
    respond "Supabase minimal endpoint — use /rest/v1, /auth/v1, or /realtime/v1" 200
}

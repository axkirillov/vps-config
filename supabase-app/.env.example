# Supabase minimal self-host configuration
# Runs: PostgreSQL + GoTrue (Auth) + PostgREST (REST) + Realtime (WebSocket)

# Postgres
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# JWT - your app will use these keys to talk to PostgREST and Realtime
JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long
JWT_EXPIRY=3600

# Pre-signed API keys (JWTs signed with JWT_SECRET)
# Generate with: bash generate-keys.sh
# - ANON_KEY: use in client-side code (RLS policies apply)
# - SERVICE_ROLE_KEY: use in server-side code only (bypasses RLS)
ANON_KEY=changeme
SERVICE_ROLE_KEY=changeme

# PostgREST
PGRST_DB_SCHEMAS=public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Realtime
SECRET_KEY_BASE=change-me-to-a-secret-at-least-64-characters-long

# Public URL (used by client SDKs to reach the API)
SUPABASE_PUBLIC_URL=https://supabase.axkirillov.com
API_EXTERNAL_URL=https://supabase.axkirillov.com

# Auth (GoTrue)
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# SMTP — needed for password reset emails and signup confirmations
# Set ENABLE_EMAIL_AUTOCONFIRM=true to skip signup emails
# For production, configure a real SMTP server (AWS SES, SendGrid, Gmail, etc.)
SMTP_ADMIN_EMAIL=admin@axkirillov.com
SMTP_HOST=mail
SMTP_PORT=587
SMTP_USER=dummy
SMTP_PASS=dummy
SMTP_SENDER_NAME=Supabase

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

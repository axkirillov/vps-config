# Supabase minimal self-host configuration
# This runs only: PostgreSQL + PostgREST + Realtime (no Auth, no Studio, no Storage)

# Postgres
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# JWT - your app will use these keys to talk to PostgREST and Realtime
JWT_SECRET=change-me-to-a-secret-at-least-32-characters-long
JWT_EXPIRY=3600

# Pre-signed API keys (JWTs signed with JWT_SECRET)
# Generate with: bash generate-keys.sh
# - ANON_KEY: use in client-side code (RLS policies apply)
# - SERVICE_ROLE_KEY: use in server-side code only (bypasses RLS)
ANON_KEY=changeme
SERVICE_ROLE_KEY=changeme

# PostgREST
PGRST_DB_SCHEMAS=public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

# Realtime
SECRET_KEY_BASE=change-me-to-a-secret-at-least-64-characters-long

# Public URL (used by Realtime)
SUPABASE_PUBLIC_URL=https://supabase.axkirillov.com
